  "support_q1": { "zh": "如何购买游戏？", "en": "How do I buy a game?", "ja": "ゲームはどう購入しますか？", "ko": "게임은 어떻게 구매하나요?" },
  "support_a1": { "zh": "登录后将游戏加入购物车，在购物车页完成购买即可入库。", "en": "Sign in, add a game to your cart, then finish checkout from the cart page.", "ja": "ログイン後にカートへ追加し、カートページで購入を完了してください。", "ko": "로그인 후 장바구니에 담고 장바구니 페이지에서 결제를 완료하세요." },
  "support_q2": { "zh": "演示账号是什么？", "en": "What demo account can I use?", "ja": "デモアカウントはありますか？", "ko": "데모 계정이 있나요?" },
